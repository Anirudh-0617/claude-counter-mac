{
  "manifest_version": 3,
  "name": "Claude Counter — macOS Enhanced",
  "version": "1.0.0",
  "description": "Real-time token counter, cache timer, cost estimator, and usage bars for Claude.ai. Built for macOS Chrome.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Claude Counter",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "css": ["src/styles.css"],
      "js": [
        "src/content/constants.js",
        "src/content/bridge-client.js",
        "src/content/tokens.js",
        "src/content/ui.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected/bridge.js"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
